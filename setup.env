#!/usr/bin/env bash
# ============================================================
#  SETUP.ENV — Configuration centrale du template Bug Bounty
#  Editer ce fichier avant de lancer le pipeline
#  Usage: source setup.env && bash RUN_ALL.sh
# ============================================================

# --- Programme ---
export BBP_PROGRAM_NAME="Remitly"          # Nom du programme (pour les logs)
export BBP_PLATFORM="hackerone"            # hackerone | bugcrowd | intigriti | yeswehack

# --- Répertoire de base (auto-détecté si laissé vide) ---
export BBP_BASE="${BBP_BASE:-$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)}"

# --- Domaines racines à énumérer (séparés par des espaces) ---
export BBP_DOMAINS="remitly.com rewire.com remitly.io"

# --- Domaines passifs pour waybackurls/gau (séparés par des espaces) ---
export BBP_PASSIVE_DOMAINS="remitly.com rewire.com"

# --- Cibles prioritaires pour scan actif (0-reports, scope critique) ---
# Format: une URL par ligne dans config/priority_targets.txt
# Ou surcharger ici (séparées par des espaces, utilisé dans les scripts)
export BBP_PRIORITY_TARGETS_FILE="${BBP_BASE}/config/priority_targets.txt"

# --- Cibles pour feroxbuster (API principale) ---
export BBP_FEROX_TARGET="https://api.remitly.io"

# --- Cible pour ffuf dir brute ---
export BBP_FFUF_TARGET="https://auth.remitly.com"

# --- URL OOB pour SSRF (interactsh ou webhook.site) ---
# Générer sur https://app.interactsh.com ou https://webhook.site
export BBP_COLLAB="REPLACE_WITH_YOUR_OOB_URL"   # ex: abc123.oast.fun

# --- Chemins outils (auto-détectés si dans PATH) ---
export BBP_SECLISTS="${HOME}/SecLists"
export BBP_NUCLEI_TEMPLATES="${HOME}/nuclei-templates"
export BBP_SECRETFINDER="${HOME}/tools/SecretFinder/SecretFinder.py"
export BBP_DIRSEARCH="${HOME}/Documents/CSH/dirsearch/dirsearch.py"

# --- Limites (ajuster selon connexion et règles du programme) ---
export BBP_THREADS_HIGH=50
export BBP_THREADS_MED=30
export BBP_THREADS_LOW=20
export BBP_RATE_LIMIT_NUCLEI=50
export BBP_TIMEOUT=10

# --- Origines CORS à tester ---
# Adapter: remplacer "remitly" par le domaine du programme cible
export BBP_CORS_ORIGINS="https://evil.com https://remitly.com.evil.com https://evil-remitly.com null https://remitly.com"

# ============================================================
#  VALIDATION — Ne pas modifier
# ============================================================
_bbp_validate() {
    local ok=1
    [ -z "$BBP_DOMAINS" ]          && echo "[WARN] BBP_DOMAINS non défini" && ok=0
    [ -z "$BBP_PASSIVE_DOMAINS" ]  && echo "[WARN] BBP_PASSIVE_DOMAINS non défini" && ok=0
    [ "$BBP_COLLAB" = "REPLACE_WITH_YOUR_OOB_URL" ] && echo "[WARN] BBP_COLLAB non configuré — SSRF désactivé"
    [ ! -d "$BBP_SECLISTS" ]       && echo "[WARN] SecLists introuvable: $BBP_SECLISTS"
    [ ! -d "$BBP_NUCLEI_TEMPLATES" ] && echo "[WARN] nuclei-templates introuvable: $BBP_NUCLEI_TEMPLATES"
    echo "[+] Config chargée pour: $BBP_PROGRAM_NAME ($BBP_PLATFORM)"
    return $ok
}
_bbp_validate
